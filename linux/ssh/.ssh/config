# 1Password SSH Agent (Linux, if running locally on this machine)
# Requires: 1Password Desktop App with SSH Agent enabled
# Settings > Developer > SSH Agent
Match exec "test -S %d/.1password/agent.sock"
  IdentityAgent "~/.1password/agent.sock"

# Fallback agent: whatever SSH_AUTH_SOCK points to.
# Covers Docker containers with bind-mounted agent socket and plain ssh -A
# forwarded agent. Without this the above rule would drop back to the OpenSSH
# default (ignore the env var) when the 1Password socket is absent, producing
# "Permission denied (publickey)".
Host *
  IdentityAgent SSH_AUTH_SOCK

# Include local host configs (not in dotfiles)
Include ~/.ssh/config.d/*
