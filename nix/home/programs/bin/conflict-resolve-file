#!/usr/bin/env bash
# conflict-resolve-file: 単一ファイルのコンフリクトを claude -p で解消する
set -euo pipefail

# claude コマンドの存在確認
if ! command -v claude &>/dev/null; then
  echo "Error: claude command not found." >&2
  exit 1
fi

# 引数パース
BASE=""
OURS=""
THEIRS=""
REPO_PATH=""
SAVE_DIR=""
REVIEW_COMMENTS=""
COMMIT_MSG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)
      BASE="$2"
      shift 2
      ;;
    --ours)
      OURS="$2"
      shift 2
      ;;
    --theirs)
      THEIRS="$2"
      shift 2
      ;;
    --path)
      REPO_PATH="$2"
      shift 2
      ;;
    --save-dir)
      SAVE_DIR="$2"
      shift 2
      ;;
    --review-comments)
      REVIEW_COMMENTS="$2"
      shift 2
      ;;
    --commit-message)
      COMMIT_MSG="$2"
      shift 2
      ;;
    *)
      echo "Error: Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

# 必須引数チェック
for arg_name in BASE OURS THEIRS REPO_PATH SAVE_DIR; do
  if [[ -z "${!arg_name}" ]]; then
    echo "Error: --$(echo "$arg_name" | tr '[:upper:]' '[:lower:]' | tr '_' '-') is required." >&2
    exit 1
  fi
done

# ファイル読み込み
base_content=$(cat "$BASE")
ours_content=$(cat "$OURS")
theirs_content=$(cat "$THEIRS")

# コミットログ収集
commit_context=""
if git rev-parse --is-inside-work-tree &>/dev/null; then
  MERGE_BASE_SHA=$(git merge-base ORIG_HEAD "$(git rev-parse HEAD)" 2>/dev/null || true)
  if [[ -n "$MERGE_BASE_SHA" ]]; then
    ours_log=$(git log --oneline "${MERGE_BASE_SHA}..ORIG_HEAD" -- "$REPO_PATH" 2>/dev/null || true)
    theirs_log=$(git log --oneline "${MERGE_BASE_SHA}..HEAD" -- "$REPO_PATH" 2>/dev/null || true)
    if [[ -n "$ours_log" || -n "$theirs_log" ]]; then
      commit_context="
<commit_context>
ours side changes:
${ours_log:-（none）}

theirs side changes:
${theirs_log:-（none）}
</commit_context>"
    fi
  fi
fi

# REVIEW: コメント構文の決定
ext="${REPO_PATH##*.}"
case "$ext" in
  ts|tsx|js|jsx|go|rs|java|c|cpp|h|hpp)
    review_syntax='// REVIEW: <message>'
    ;;
  py|rb|sh|bash|yaml|yml|toml)
    review_syntax='# REVIEW: <message>'
    ;;
  lua)
    review_syntax='-- REVIEW: <message>'
    ;;
  html|xml|vue|svelte)
    review_syntax='<!-- REVIEW: <message> -->'
    ;;
  *)
    review_syntax='// REVIEW: <message>'
    ;;
esac

# レビューフィードバックセクション
review_section=""
if [[ -n "$REVIEW_COMMENTS" ]]; then
  review_section="
<review_feedback>
The user has provided the following feedback on the previous resolution.
Reflect this feedback and re-resolve the conflict:

${REVIEW_COMMENTS}
</review_feedback>"
fi

# コミットメッセージセクション (存在する場合のみ)
commit_msg_section=""
if [[ -n "$COMMIT_MSG" ]]; then
  commit_msg_section="
COMMIT MESSAGE (the commit being applied):
${COMMIT_MSG}
"
fi

# プロンプト構築
prompt="You are resolving a merge conflict for file: ${REPO_PATH}
${commit_msg_section}${commit_context}
BASE (common ancestor):
${base_content}

OURS (current branch):
${ours_content}

THEIRS (incoming branch):
${theirs_content}
${review_section}
Resolve this conflict by merging both changes. Output EXACTLY this XML format:

<resolved>
...resolved file content here...
</resolved>
<confidence>high or needs-review</confidence>
<review_comment>explanation of how you resolved the conflict</review_comment>

## Rules

DEFAULT CONFIDENCE IS needs-review. Use \"high\" ONLY for these mechanical cases:
- Import/require/use statements: merging additions from both sides
- Whitespace or formatting differences only
- Independent additions to different sections of the file (no overlap in logic)
- Comment-only changes

Everything else is needs-review. Specifically:
- Any function, method, class, or export that exists in one side but not the other
- Any error handling (try-catch, validation, conditionals) added or removed
- Any architectural pattern change (e.g., direct calls replaced with RPC/abstraction)
- Any stub or \"not implemented\" replacement
- Anything you are not 100% certain about

## Resolution Approach

1. PRESERVE FUNCTIONALITY FROM BOTH SIDES
   - Never silently drop functions, methods, exports, or implementations
   - If one side deletes/stubs code that the other side implements, KEEP the implementation

2. CONFIG / DOCS / MANIFESTS = ADDITIVE MERGE
   - For .md, .yaml, .toml, .json config, .env files: keep additions from BOTH sides

3. When in doubt, include BOTH versions and add a REVIEW: comment explaining the conflict

Add REVIEW: comments (using syntax: ${review_syntax}) for each needs-review decision.
Do NOT leave any conflict markers (<<<<<<, ======, >>>>>>) in the output."

# claude -p で解決
output=$(echo "$prompt" | claude -p 2>/dev/null)

# XML パース: resolved (複数行)
resolved=$(echo "$output" | sed -n '/<resolved>/,/<\/resolved>/p' | sed '1d;$d')
if [[ -z "$resolved" ]]; then
  echo "Error: Failed to parse <resolved> from claude output." >&2
  exit 1
fi

# XML パース: confidence (1行)
confidence=$(echo "$output" | sed -n 's/.*<confidence>\(.*\)<\/confidence>.*/\1/p')
if [[ -z "$confidence" ]]; then
  echo "Error: Failed to parse <confidence> from claude output." >&2
  exit 1
fi

# XML パース: review_comment (1行)
review_comment=$(echo "$output" | sed -n 's/.*<review_comment>\(.*\)<\/review_comment>.*/\1/p')
if [[ -z "$review_comment" ]]; then
  echo "Error: Failed to parse <review_comment> from claude output." >&2
  exit 1
fi

# 結果書き込み
mkdir -p "$SAVE_DIR"
printf '%s\n' "$resolved" > "${SAVE_DIR}/resolved"
printf '%s\n' "$confidence" > "${SAVE_DIR}/confidence"
printf '%s\n' "$review_comment" > "${SAVE_DIR}/review_comment"

# $OURS ファイル (%A) にも resolved 内容をコピー (conflict-driver からの呼び出し時用)
cp "${SAVE_DIR}/resolved" "$OURS"
