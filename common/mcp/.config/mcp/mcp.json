{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "description": "Library documentation lookup (Context7)",
      "permission": "allow",
      "enabled": true
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "description": "Browser automation for UI testing and web fetch fallback",
      "permission": "ask",
      "enabled": false
    },
    "filesystem-readonly": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@latest", "."],
      "description": "Read-only filesystem access",
      "permission": "ask",
      "enabled": false
    }
  }
}
