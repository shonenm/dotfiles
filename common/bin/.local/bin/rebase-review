#!/usr/bin/env bash
# rebase-review: rebase 完了後にコンフリクト解決結果を 3-way diff でレビューする
# merge review と同等の aggregate view: ours(ORIG_HEAD) | resolved(HEAD) | theirs(target)
set -euo pipefail

# ORIG_HEAD の存在確認
if ! git rev-parse --verify ORIG_HEAD &>/dev/null; then
  echo "Error: ORIG_HEAD not found. Not in a post-rebase state."
  exit 1
fi

# ベースの決定: 引数 > reflog 検出 > デフォルトブランチ
if [[ $# -ge 1 ]]; then
  BASE_REF="$1"
elif BASE_REF=$(git reflog --format='%gs' | sed -n 's/^rebase (start): checkout \(.*\)/\1/p;T;q') && [[ -n "$BASE_REF" ]]; then
  echo "Detected rebase target from reflog: $BASE_REF" >&2
else
  DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
  BASE_REF="origin/${DEFAULT_BRANCH:-main}"
  echo "Using default base: $BASE_REF" >&2
fi

TARGET=$(git rev-parse "$BASE_REF")
MERGE_BASE=$(git merge-base ORIG_HEAD "$TARGET")

# 両ブランチが変更したファイル (intersection)
both_files=$(comm -12 \
  <(git diff --name-only "$MERGE_BASE" ORIG_HEAD | sort) \
  <(git diff --name-only "$MERGE_BASE" "$TARGET" | sort))

if [[ -z "$both_files" ]]; then
  echo "No files modified by both branches."
  exit 0
fi

TMPDIR=$(mktemp -d /tmp/rebase_review_XXXXXX)
trap 'rm -rf "$TMPDIR"' EXIT

SCRIPT="${TMPDIR}/review.lua"
first=true
tab_count=0

while IFS= read -r file_path; do
  # blob hash で比較 (内容の一致判定)
  head_hash=$(git rev-parse "HEAD:${file_path}" 2>/dev/null || echo "none")
  orig_hash=$(git rev-parse "ORIG_HEAD:${file_path}" 2>/dev/null || echo "none")
  target_hash=$(git rev-parse "${TARGET}:${file_path}" 2>/dev/null || echo "none")

  # HEAD が ours と同じ → rebase で変更なし、レビュー不要
  [[ "$head_hash" == "$orig_hash" ]] && continue
  # HEAD が theirs と同じ → theirs をそのまま採用、レビュー不要
  [[ "$head_hash" == "$target_hash" ]] && continue

  # 3状態を一時ファイルに書き出し
  file_dir="${TMPDIR}/files/${file_path}"
  mkdir -p "$file_dir"

  ours_file="${file_dir}/ours"
  resolved_file="${file_dir}/resolved"
  theirs_file="${file_dir}/theirs"

  git show "ORIG_HEAD:${file_path}" > "$ours_file" 2>/dev/null || echo -n > "$ours_file"
  git show "HEAD:${file_path}" > "$resolved_file" 2>/dev/null || continue
  git show "${TARGET}:${file_path}" > "$theirs_file" 2>/dev/null || echo -n > "$theirs_file"

  if [[ "$first" == "true" ]]; then
    first=false
  else
    echo 'vim.cmd("tabnew")' >> "$SCRIPT"
  fi
  tab_count=$((tab_count + 1))

  # パス内の ' をエスケープ (Lua 文字列リテラルに安全に埋め込む)
  OURS_ESC=$(printf '%s' "$ours_file" | sed "s/'/\\\\'/g")
  RESOLVED_ESC=$(printf '%s' "$resolved_file" | sed "s/'/\\\\'/g")
  THEIRS_ESC=$(printf '%s' "$theirs_file" | sed "s/'/\\\\'/g")
  FILE_PATH_ESC=$(printf '%s' "$file_path" | sed "s/'/\\\\'/g")

  cat >> "$SCRIPT" << EOF
do
  local saved_ei = vim.o.eventignore
  vim.o.eventignore = "all"
  vim.cmd("edit " .. vim.fn.fnameescape('${OURS_ESC}'))
  vim.bo.buflisted = false
  local ft = vim.filetype.match({ filename = '${FILE_PATH_ESC}' })
  if ft then vim.bo.filetype = ft end
  vim.cmd("vertical split " .. vim.fn.fnameescape('${RESOLVED_ESC}'))
  vim.cmd("vertical split " .. vim.fn.fnameescape('${THEIRS_ESC}'))
  vim.bo.buflisted = false
  if ft then vim.bo.filetype = ft end
  vim.o.eventignore = saved_ei
  vim.api.nvim_tabpage_set_var(0, 'review_label', '${FILE_PATH_ESC}')
end
EOF
done <<< "$both_files"

if [[ "$first" == "true" ]]; then
  echo "No conflict resolutions to review."
  exit 0
fi

cat >> "$SCRIPT" << 'LUAEOF'
function _rebase_review_tabline()
  local tabpages = vim.api.nvim_list_tabpages()
  local current = vim.api.nvim_get_current_tabpage()
  local current_idx = 0
  local total = #tabpages
  local entries = {}
  for i, tp in ipairs(tabpages) do
    if tp == current then current_idx = i end
    local ok, label = pcall(vim.api.nvim_tabpage_get_var, tp, 'review_label')
    entries[i] = { tp = tp, label = ok and label or tostring(i) }
  end
  local cols = vim.o.columns
  local indicator = ' ' .. current_idx .. '/' .. total .. ' '
  local avail = cols - #indicator - 4
  local function entry_width(e) return #e.label + 2 end
  local lo, hi = current_idx, current_idx
  local used = entry_width(entries[current_idx])
  while true do
    local expanded = false
    if lo > 1 and used + entry_width(entries[lo - 1]) <= avail then
      lo = lo - 1; used = used + entry_width(entries[lo]); expanded = true
    end
    if hi < total and used + entry_width(entries[hi + 1]) <= avail then
      hi = hi + 1; used = used + entry_width(entries[hi]); expanded = true
    end
    if not expanded then break end
  end
  local s = ''
  if lo > 1 then s = s .. '%#TabLine# < ' end
  for i = lo, hi do
    local hl = (entries[i].tp == current) and '%#TabLineSel#' or '%#TabLine#'
    s = s .. hl .. '%' .. i .. 'T ' .. entries[i].label .. ' '
  end
  if hi < total then s = s .. '%#TabLine# > ' end
  s = s .. '%#TabLineFill#%T%=%#TabLine#' .. indicator
  return s
end
vim.o.showtabline = 2
vim.o.tabline = '%!v:lua._rebase_review_tabline()'
vim.cmd('tabfirst')
LUAEOF

echo "Opening ${tab_count} file(s) for review..."

REPO_ROOT=$(git rev-parse --show-toplevel)

nvim -S "$SCRIPT"

# REVIEW: コメント残存チェック
REVIEW_REMAINING=$(grep -rn "REVIEW:" "$REPO_ROOT" \
  --exclude-dir=node_modules --exclude-dir=.git --exclude-dir=vendor \
  --exclude-dir=dist --exclude-dir=build --exclude-dir=target \
  --include="*.ts" --include="*.tsx" --include="*.js" --include="*.jsx" \
  --include="*.go" --include="*.rs" --include="*.java" \
  --include="*.py" --include="*.rb" --include="*.sh" \
  --include="*.lua" --include="*.vue" --include="*.html" \
  2>/dev/null || true)

if [[ -n "$REVIEW_REMAINING" ]]; then
  echo ""
  echo "Warning: REVIEW: comments remain:"
  echo "$REVIEW_REMAINING"
fi

# アクション選択
echo ""
echo "Review complete."
echo ""
echo "  a) Accept - approve rebase result"
echo "  m) Amend - amend latest commit (git commit --amend)"
echo "  e) Exit - do nothing"
echo ""
read -rp "Action [a/m/e]: " -n 1 action || true
echo ""

case "$action" in
  a|A)
    echo "Rebase result accepted."
    ;;
  m|M)
    if [[ -n "$REVIEW_REMAINING" ]]; then
      read -rp "REVIEW: comments remain. Continue with amend? [y/N]: " -n 1 yn || true
      echo ""
      [[ "$yn" =~ ^[Yy]$ ]] || { echo "Cancelled."; exit 0; }
    fi
    git commit --amend
    ;;
  e|E)
    echo "No action taken."
    ;;
  *)
    echo "No action taken."
    ;;
esac
