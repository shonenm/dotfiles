#!/usr/bin/env bash
# rebase-review: rebase 完了後にコンフリクト解決結果を 3-way diff でレビューする
# merge review と同等の aggregate view: ours(ORIG_HEAD) | resolved(HEAD) | theirs(target)
# レビューループ: REVIEW: コメントで Claude に再解消を依頼可能
set -euo pipefail

# 前提チェック
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "Error: Not inside a git repository." >&2
  exit 1
fi

if git rev-parse --verify REBASE_HEAD &>/dev/null; then
  echo "Error: Rebase is still in progress (REBASE_HEAD exists)." >&2
  echo "Complete or abort the rebase first." >&2
  exit 1
fi

if ! git rev-parse --verify ORIG_HEAD &>/dev/null; then
  echo "Error: ORIG_HEAD not found. Not in a post-rebase state." >&2
  exit 1
fi

REPO_ROOT=$(git rev-parse --show-toplevel)

# ベースの決定: 引数 > reflog 検出 > デフォルトブランチ
if [[ $# -ge 1 ]]; then
  BASE_REF="$1"
elif BASE_REF=$(git reflog --format='%gs' | sed -n 's/^rebase (start): checkout \(.*\)/\1/p;T;q') && [[ -n "$BASE_REF" ]]; then
  echo "Detected rebase target from reflog: $BASE_REF" >&2
else
  DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
  BASE_REF="origin/${DEFAULT_BRANCH:-main}"
  echo "Using default base: $BASE_REF" >&2
fi

TARGET=$(git rev-parse "$BASE_REF")
ORIG_HEAD=$(git rev-parse ORIG_HEAD)
MERGE_BASE=$(git merge-base "$ORIG_HEAD" "$TARGET")

# 両ブランチが変更したファイル (intersection)
both_files=$(comm -12 \
  <(git diff --name-only "$MERGE_BASE" "$ORIG_HEAD" | sort) \
  <(git diff --name-only "$MERGE_BASE" "$TARGET" | sort))

if [[ -z "$both_files" ]]; then
  echo "No files modified by both branches."
  exit 0
fi

TMPDIR=$(mktemp -d /tmp/rebase_review_XXXXXX)
trap 'rm -rf "$TMPDIR"' EXIT

# レビュー対象ファイル特定 (hash 比較でフィルタ)
review_files=()
while IFS= read -r file_path; do
  head_hash=$(git rev-parse "HEAD:${file_path}" 2>/dev/null || echo "none")
  orig_hash=$(git rev-parse "ORIG_HEAD:${file_path}" 2>/dev/null || echo "none")
  target_hash=$(git rev-parse "${TARGET}:${file_path}" 2>/dev/null || echo "none")

  # HEAD が ours と同じ → rebase で変更なし、レビュー不要
  [[ "$head_hash" == "$orig_hash" ]] && continue
  # HEAD が theirs と同じ → theirs をそのまま採用、レビュー不要
  [[ "$head_hash" == "$target_hash" ]] && continue

  review_files+=("$file_path")
done <<< "$both_files"

if [[ ${#review_files[@]} -eq 0 ]]; then
  echo "No conflict resolutions to review."
  exit 0
fi

# 一時ファイル生成 (ours/theirs)
for file_path in "${review_files[@]}"; do
  file_dir="${TMPDIR}/files/${file_path}"
  mkdir -p "$file_dir"

  ours_file="${file_dir}/ours"
  theirs_file="${file_dir}/theirs"

  git show "ORIG_HEAD:${file_path}" > "$ours_file" 2>/dev/null || echo -n > "$ours_file"
  git show "${TARGET}:${file_path}" > "$theirs_file" 2>/dev/null || echo -n > "$theirs_file"
done

# Lua スクリプト生成関数
generate_lua() {
  local script="$1"
  local first=true
  local tab_count=0

  for file_path in "${review_files[@]}"; do
    local file_dir="${TMPDIR}/files/${file_path}"
    local ours_file="${file_dir}/ours"
    local resolved_file="${REPO_ROOT}/${file_path}"
    local theirs_file="${file_dir}/theirs"

    if [[ "$first" == "true" ]]; then
      first=false
    else
      echo 'vim.cmd("tabnew")' >> "$script"
    fi
    tab_count=$((tab_count + 1))

    # パス内の ' をエスケープ (Lua 文字列リテラルに安全に埋め込む)
    local OURS_ESC RESOLVED_ESC THEIRS_ESC FILE_PATH_ESC
    OURS_ESC=$(printf '%s' "$ours_file" | sed "s/'/\\\\'/g")
    RESOLVED_ESC=$(printf '%s' "$resolved_file" | sed "s/'/\\\\'/g")
    THEIRS_ESC=$(printf '%s' "$theirs_file" | sed "s/'/\\\\'/g")
    FILE_PATH_ESC=$(printf '%s' "$file_path" | sed "s/'/\\\\'/g")

    cat >> "$script" << EOF
do
  local saved_ei = vim.o.eventignore
  vim.o.eventignore = "all"
  vim.cmd("edit " .. vim.fn.fnameescape('${OURS_ESC}'))
  vim.bo.buflisted = false
  vim.cmd("vertical split " .. vim.fn.fnameescape('${RESOLVED_ESC}'))
  vim.cmd("vertical split " .. vim.fn.fnameescape('${THEIRS_ESC}'))
  vim.bo.buflisted = false
  vim.o.eventignore = saved_ei
  vim.api.nvim_tabpage_set_var(0, 'review_label', '${FILE_PATH_ESC}')
end
EOF
  done

  cat >> "$script" << 'LUAEOF'
do
  local bg = vim.o.background == 'dark' and 'dark' or 'light'
  if bg == 'dark' then
    vim.api.nvim_set_hl(0, 'ReviewTabSel', { fg = '#1a1b26', bg = '#7aa2f7', bold = true })
    vim.api.nvim_set_hl(0, 'ReviewTab', { fg = '#a9b1d6', bg = '#3b3d57' })
    vim.api.nvim_set_hl(0, 'ReviewTabFill', { fg = '#565873', bg = '#1a1b26' })
  else
    vim.api.nvim_set_hl(0, 'ReviewTabSel', { fg = '#ffffff', bg = '#3d59a1', bold = true })
    vim.api.nvim_set_hl(0, 'ReviewTab', { fg = '#343b58', bg = '#c4c8da' })
    vim.api.nvim_set_hl(0, 'ReviewTabFill', { fg = '#9699a3', bg = '#e1e2e7' })
  end
end
function _rebase_review_tabline()
  local tabpages = vim.api.nvim_list_tabpages()
  local current = vim.api.nvim_get_current_tabpage()
  local current_idx = 0
  local total = #tabpages
  local entries = {}
  for i, tp in ipairs(tabpages) do
    if tp == current then current_idx = i end
    local ok, label = pcall(vim.api.nvim_tabpage_get_var, tp, 'review_label')
    entries[i] = { tp = tp, label = ok and label or tostring(i) }
  end
  local cols = vim.o.columns
  local indicator = ' ' .. current_idx .. '/' .. total .. ' '
  local avail = cols - #indicator - 2
  local function entry_width(e) return #e.label + 4 end
  local lo, hi = current_idx, current_idx
  local used = entry_width(entries[current_idx])
  while true do
    local expanded = false
    if lo > 1 and used + entry_width(entries[lo - 1]) <= avail then
      lo = lo - 1; used = used + entry_width(entries[lo]); expanded = true
    end
    if hi < total and used + entry_width(entries[hi + 1]) <= avail then
      hi = hi + 1; used = used + entry_width(entries[hi]); expanded = true
    end
    if not expanded then break end
  end
  local s = ''
  if lo > 1 then s = s .. '%#ReviewTabFill# < ' end
  for i = lo, hi do
    local hl = (entries[i].tp == current) and '%#ReviewTabSel#' or '%#ReviewTab#'
    s = s .. hl .. '%' .. i .. 'T  ' .. entries[i].label .. '  '
  end
  if hi < total then s = s .. '%#ReviewTabFill# > ' end
  s = s .. '%#ReviewTabFill#%T%=%#ReviewTabSel# ' .. indicator
  return s
end
local function apply_review_tabline()
  vim.o.showtabline = 2
  vim.o.tabline = '%!v:lua._rebase_review_tabline()'
end
apply_review_tabline()
vim.cmd('tabfirst')
-- bufferline.nvim が複数イベントで tabline を上書きするため、継続的に再設定する
vim.api.nvim_create_autocmd({'VimEnter', 'BufEnter', 'TabEnter', 'TabNew', 'TabClosed'}, {
  callback = function()
    vim.schedule(function()
      if vim.o.tabline ~= '%!v:lua._rebase_review_tabline()' then
        apply_review_tabline()
      end
    end)
  end,
})
LUAEOF

  echo "$tab_count"
}

# REVIEW: コメント収集 (レビュー対象ファイルのみ)
collect_review_comments() {
  local comments=""
  for file_path in "${review_files[@]}"; do
    local result
    result=$(grep -n "REVIEW:" "${REPO_ROOT}/${file_path}" 2>/dev/null || true)
    if [[ -n "$result" ]]; then
      comments+="--- ${file_path} ---"$'\n'
      comments+="${result}"$'\n'
    fi
  done
  echo "$comments"
}

# Claude で再解消
re_resolve_with_claude() {
  local comments="$1"
  local resolved_any=false

  for file_path in "${review_files[@]}"; do
    # このファイルに REVIEW: コメントがあるかチェック
    local file_comments
    file_comments=$(grep -n "REVIEW:" "${REPO_ROOT}/${file_path}" 2>/dev/null || true)
    [[ -z "$file_comments" ]] && continue

    resolved_any=true
    echo "Re-resolving: ${file_path}" >&2

    local file_dir="${TMPDIR}/files/${file_path}"
    local base_file="${file_dir}/base"
    local ours_file="${file_dir}/ours"
    local theirs_file="${file_dir}/theirs"
    local save_dir="${file_dir}/resolve"
    mkdir -p "$save_dir"

    # base を生成
    git show "${MERGE_BASE}:${file_path}" > "$base_file" 2>/dev/null || echo -n > "$base_file"

    # conflict-resolve-file で再解消
    conflict-resolve-file \
      --base "$base_file" \
      --ours "$ours_file" \
      --theirs "$theirs_file" \
      --path "$file_path" \
      --save-dir "$save_dir" \
      --review-comments "$file_comments"

    # 結果を実ファイルに反映
    if [[ -f "${save_dir}/resolved" ]]; then
      cp "${save_dir}/resolved" "${REPO_ROOT}/${file_path}"
      echo "  Updated: ${file_path}" >&2
    else
      echo "  Warning: No resolved output for ${file_path}" >&2
    fi
  done

  if [[ "$resolved_any" == "false" ]]; then
    echo "No files with REVIEW: comments found." >&2
    return 1
  fi
  return 0
}

# メインループ
while true; do
  SCRIPT="${TMPDIR}/review.lua"
  : > "$SCRIPT"

  tab_count=$(generate_lua "$SCRIPT")

  echo "Opening ${tab_count} file(s) for review..."
  nvim -S "$SCRIPT"

  # REVIEW: コメント収集
  REVIEW_COMMENTS=$(collect_review_comments)

  if [[ -n "$REVIEW_COMMENTS" ]]; then
    echo ""
    echo "REVIEW: comments found:"
    echo "$REVIEW_COMMENTS"
  fi

  # アクション選択
  echo ""
  echo "Review complete."
  echo ""
  echo "  r) Re-resolve - send REVIEW: comments to Claude for re-resolution"
  echo "  c) Accept - approve rebase result"
  echo "  m) Amend - amend latest commit (git commit --amend)"
  echo "  e) Exit - do nothing"
  echo ""
  read -rp "Action [r/c/m/e]: " -n 1 action || true
  echo ""

  case "$action" in
    r|R)
      if [[ -z "$REVIEW_COMMENTS" ]]; then
        echo "No REVIEW: comments found. Nothing to re-resolve."
        continue
      fi
      echo "Sending REVIEW: comments to Claude for re-resolution..."
      if re_resolve_with_claude "$REVIEW_COMMENTS"; then
        echo "Re-resolution complete. Reopening for review..."
      else
        echo "Re-resolution failed or no files to process."
      fi
      # ループ先頭に戻る
      ;;
    c|C)
      echo "Rebase result accepted."
      break
      ;;
    m|M)
      REVIEW_REMAINING=$(collect_review_comments)
      if [[ -n "$REVIEW_REMAINING" ]]; then
        read -rp "REVIEW: comments remain. Continue with amend? [y/N]: " -n 1 yn || true
        echo ""
        [[ "$yn" =~ ^[Yy]$ ]] || continue
      fi
      git commit --amend
      break
      ;;
    e|E)
      echo "No action taken."
      break
      ;;
    *)
      echo "No action taken."
      break
      ;;
  esac
done
