#!/usr/bin/env bash
# conflict-review: コンフリクト解決後に ours | resolved | theirs の3way diff を起動
# 全ファイルをタブで一括表示し、レビュー後のアクションを選択できる
set -euo pipefail

SESSION_DIR="/tmp/conflict_session/$(printf '%s' "$(git rev-parse --absolute-git-dir)" | (md5sum 2>/dev/null || md5) | cut -c1-12)"

if [[ ! -d "$SESSION_DIR" ]]; then
  echo "Error: No conflict session found for this worktree. Run 'conflict-save' first."
  exit 1
fi

# 操作種別判定
OP_TYPE="unknown"
if [[ -f "${SESSION_DIR}/type" ]]; then
  OP_TYPE=$(cat "${SESSION_DIR}/type")
fi

# ファイル検出: ours ファイルをディレクトリベースで探索
REVIEW_FILES=()
while IFS= read -r ours_path; do
  # /tmp/conflict_session/<sha>/<file_path>/ours → file_path を抽出
  file_path="${ours_path#"${SESSION_DIR}/"}"  # <sha>/<file_path>/ours
  file_path="${file_path#*/}"                  # <file_path>/ours
  file_path="${file_path%/ours}"               # <file_path>
  REVIEW_FILES+=("$file_path")
done < <(find "$SESSION_DIR" -name "ours" -not -path "*/.*" | sort)

if [[ ${#REVIEW_FILES[@]} -eq 0 ]]; then
  echo "No files to review."
  exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel)

echo "Reviewing ${#REVIEW_FILES[@]} file(s)..."

# Lua スクリプトを生成: 各ファイルを3ペインのタブとして配置
# diff 有効化・filetype 設定・キーマップは merge-review.lua プラグインが担当
SCRIPT=$(mktemp /tmp/conflict_review_XXXXXX.lua)

first=true
while IFS= read -r ours_path; do
  file_path="${ours_path#"${SESSION_DIR}/"}"
  file_path="${file_path#*/}"
  file_path="${file_path%/ours}"

  OURS="$ours_path"
  THEIRS="${ours_path%/ours}/theirs"
  RESOLVED="${REPO_ROOT}/${file_path}"

  if [[ ! -f "$RESOLVED" ]]; then
    echo "Warning: Resolved file not found: $RESOLVED (skipping)"
    continue
  fi

  if [[ "$first" == "true" ]]; then
    first=false
  else
    echo 'vim.cmd("tabnew")' >> "$SCRIPT"
  fi

  # パス内の ' をエスケープ (Lua 文字列リテラルに安全に埋め込む)
  OURS_ESC=$(printf '%s' "$OURS" | sed "s/'/\\\\'/g")
  RESOLVED_ESC=$(printf '%s' "$RESOLVED" | sed "s/'/\\\\'/g")
  THEIRS_ESC=$(printf '%s' "$THEIRS" | sed "s/'/\\\\'/g")

  cat >> "$SCRIPT" << EOF
do
  local saved_ei = vim.o.eventignore
  vim.o.eventignore = "all"
  vim.cmd("edit " .. vim.fn.fnameescape('${OURS_ESC}'))
  vim.bo.buflisted = false
  vim.cmd("vertical split " .. vim.fn.fnameescape('${RESOLVED_ESC}'))
  vim.cmd("vertical split " .. vim.fn.fnameescape('${THEIRS_ESC}'))
  vim.bo.buflisted = false
  vim.o.eventignore = saved_ei
end
EOF
done < <(find "$SESSION_DIR" -name "ours" -not -path "*/.*" | sort)

echo 'vim.cmd("tabfirst")' >> "$SCRIPT"

nvim -S "$SCRIPT"
rm -f "$SCRIPT"

# レビュー後のアクション選択
echo ""
echo "Review complete."
echo ""
case "$OP_TYPE" in
  rebase)
    echo "  c) Continue rebase (git rebase --continue)"
    ;;
  cherry-pick)
    echo "  c) Continue cherry-pick (git cherry-pick --continue)"
    ;;
  *)
    echo "  c) Commit (approve merge)"
    ;;
esac
echo "  e) Request modifications (files remain staged)"
echo "  a) Abort"
echo ""
read -rp "Action [c/e/a]: " -n 1 action || true
echo ""

case "$action" in
  c|C)
    # REVIEW: コメントが残っていないか確認
    REVIEW_REMAINING=$(grep -rn "REVIEW:" "$REPO_ROOT" \
      --exclude-dir=node_modules --exclude-dir=.git --exclude-dir=vendor \
      --exclude-dir=dist --exclude-dir=build --exclude-dir=target \
      --include="*.ts" --include="*.tsx" --include="*.js" --include="*.jsx" \
      --include="*.go" --include="*.rs" --include="*.java" \
      --include="*.py" --include="*.rb" --include="*.sh" \
      --include="*.lua" --include="*.vue" --include="*.html" \
      2>/dev/null || true)
    if [[ -n "$REVIEW_REMAINING" ]]; then
      echo ""
      echo "Warning: REVIEW: comments remain:"
      echo "$REVIEW_REMAINING"
      echo ""
      read -rp "Continue anyway? [y/N]: " -n 1 yn || true
      echo ""
      [[ "$yn" =~ ^[Yy]$ ]] || { echo "Cancelled."; exit 0; }
    fi
    case "$OP_TYPE" in
      rebase)      git rebase --continue ;;
      cherry-pick) git cherry-pick --continue ;;
      *)           git commit ;;
    esac
    ;;
  e|E)
    echo "Files remain staged. Modify specific files, then re-run 'conflict-review'."
    ;;
  a|A)
    case "$OP_TYPE" in
      rebase)      abort_cmd="git rebase --abort" ;;
      cherry-pick) abort_cmd="git cherry-pick --abort" ;;
      *)           abort_cmd="git merge --abort" ;;
    esac
    read -rp "Run '${abort_cmd}'? [y/N]: " -n 1 confirm || true
    echo ""
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
      $abort_cmd
      echo "Aborted."
    else
      echo "Cancelled. Files remain staged."
    fi
    ;;
  *)
    echo "No action taken. Files remain staged."
    ;;
esac
