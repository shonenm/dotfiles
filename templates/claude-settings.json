{
  "mcpServers": {
    "syntopic": {
      "type": "http",
      "url": "https://mcp.sandbox.syntopic.io/mcp"
    }
  },
  "permissions": {
    "allow": [
      "mcp__syntopic__*"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh claude complete"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh claude permission"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh claude idle"
          }
        ]
      }
    ]
  }
}
