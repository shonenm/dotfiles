{
  "tui": "fullscreen",
  "statusLine": {
    "type": "command",
    "command": "__HOME__/.claude/statusline-command.sh"
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(~/.ssh/id_*)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.local/share/ai-notify/**)",
      "Read(**/*_webhook)",
      "Read(**/credentials*)"
    ],
    "allow": [
      "mcp__myproject__*",
      "mcp__notion__*",
      "mcp__tmux__*",
      "Skill",
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "WebSearch",
      "WebFetch",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(date:*)",
      "Bash(jq:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/tmux-claude-pane.sh set idle claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/common/claude/.claude/hooks/claude-session-title.sh"
          },
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/tmux-claude-pane.sh start claude event"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/tmux-claude-pane.sh heartbeat claude event"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/tmux-claude-pane.sh heartbeat claude event"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/tmux-claude-pane.sh heartbeat claude event"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh claude complete"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh claude error"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh claude permission"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh claude idle"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/tmux-claude-pane.sh clear"
          }
        ]
      }
    ]
  }
}
