{
  "statusLine": {
    "type": "command",
    "command": "__HOME__/.commandcode/statusline-command.sh"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/tmux-claude-pane.sh start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/tmux-claude-pane.sh heartbeat"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/tmux-claude-pane.sh heartbeat"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh cmd complete"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh cmd permission"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/dotfiles/scripts/ai-notify.sh cmd idle"
          }
        ]
      }
    ]
  }
}
