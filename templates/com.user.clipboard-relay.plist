<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.clipboard-relay</string>
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/dotfiles/scripts/clipboard-relay-server</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>/tmp/clipboard-relay.err</string>
    <key>StandardOutPath</key>
    <string>/tmp/clipboard-relay.log</string>
</dict>
</plist>
