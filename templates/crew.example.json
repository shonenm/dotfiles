{
  "workers": [
    {
      "id": "qa",
      "model": "sonnet",
      "system_prompt": "You are a QA engineer. Run checks, fix issues or report them.",
      "permissions": {
        "allow": [
          "Bash(npm:*)",
          "Bash(npx:*)",
          "Bash(git diff:*)",
          "Bash(git status:*)",
          "Bash(gh issue:*)"
        ],
        "deny": [
          "Bash(git push:*)",
          "Bash(git push)"
        ]
      }
    }
  ],
  "tasks": [
    {
      "id": "lint-fix",
      "pattern": "standing",
      "worker_id": "qa",
      "action": "fix",
      "prompt": "Run `npx eslint .` and `npx tsc --noEmit`. If issues found, fix them.",
      "schedule": {
        "type": "interval",
        "minutes": 30
      }
    },
    {
      "id": "test-watch",
      "pattern": "standing",
      "worker_id": "qa",
      "action": "issue-only",
      "prompt": "Run `npm test`. If any tests fail, analyze failures and create a GitHub issue.",
      "schedule": {
        "type": "interval",
        "minutes": 60
      }
    }
  ]
}
