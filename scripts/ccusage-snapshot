#!/usr/bin/env bb
;; ccusage の終了済み月を、原本 JSONL を含まない不変集計として保存する。
;; (旧 bash+python3 版の Babashka 移植 — Phase 3)

(require '[babashka.fs :as fs]
         '[babashka.process :as p]
         '[cheshire.core :as json]
         '[clojure.string :as str])

(import '[java.time YearMonth LocalDate Instant]
        '[java.time.format DateTimeFormatter]
        '[java.security MessageDigest])

(defn die [code & msg]
  (binding [*out* *err*] (apply println msg))
  (System/exit code))

(def usage-text
  (str "Usage: ccusage-snapshot [YYYY-MM]\n\n"
       "Save all-agent daily usage and Claude project usage for a completed calendar month.\n"
       "Without an argument, saves the previous month."))

(defn getenv [k default] (or (System/getenv k) default))

;; コマンドをベクタで渡して stdout を文字列で取得 (非ゼロ終了は例外)。
(defn sh-out [cmd-vec]
  (:out (p/check (p/process (vec cmd-vec) {:out :string}))))

;; --- 月の解決 (bash の python calendar/date ブロック) ---
(defn resolve-year-month [arg]
  (if (and arg (seq arg))
    (let [m (re-matches #"(\d{4})-(\d{2})" arg)]
      (when-not m (die 1 "month must be YYYY-MM"))
      (try (YearMonth/of (parse-long (nth m 1)) (parse-long (nth m 2)))
           (catch Exception _ (die 1 "month must be YYYY-MM"))))
    ;; 引数なし: 前月 (1月なら前年12月)
    (.minusMonths (YearMonth/from (LocalDate/now)) 1)))

(defn ym->fields [^YearMonth ym]
  (let [basic DateTimeFormatter/BASIC_ISO_DATE]
    {:year          (str (.getYear ym))
     :month-number  (format "%02d" (.getMonthValue ym))
     :start-date    (.format (.atDay ym 1) basic)
     :end-date      (.format (.atEndOfMonth ym) basic)}))

(defn sha256 [path]
  (let [md (MessageDigest/getInstance "SHA-256")]
    (->> (.digest md (fs/read-all-bytes (str path)))
         (map #(format "%02x" %))
         (apply str))))

;; --- ccusage binary の解決 (CCUSAGE_BIN > ccusage > mise exec node) ---
(defn resolve-ccusage []
  (let [bin (System/getenv "CCUSAGE_BIN")]
    (cond
      (and bin (seq bin))
      (do (when-not (fs/executable? bin)
            (die 1 (str "CCUSAGE_BIN is not executable: " bin)))
          [bin])
      (fs/which "ccusage") ["ccusage"]
      (fs/which "mise")    ["mise" "exec" "node" "--" "ccusage"]
      :else (die 1 "ccusage is not installed; run install.sh first."))))

(defn ccusage-version [ccusage]
  (let [out (str/trim (sh-out (conj (vec ccusage) "--version")))
        m   (re-find #"(\d+)\.(\d+)\.(\d+)" out)]
    (when-not m (die 1 (str "Could not determine ccusage version: " out)))
    (let [version (nth m 0) major (parse-long (nth m 1))]
      (when (< major 20)
        (die 1 (str "ccusage 20 or newer is required (found: " version ").")))
      version)))

(defn -main [& args]
  (when (> (count args) 1)
    (binding [*out* *err*] (println usage-text))
    (System/exit 2))

  (let [ym       (resolve-year-month (first args))
        {:keys [year month-number start-date end-date]} (ym->fields ym)
        state-dir (str (getenv "XDG_STATE_HOME" (str (fs/home) "/.local/state")) "/ccusage")
        parent    (str state-dir "/snapshots/" year)
        snap-dir  (str parent "/" month-number)
        timezone  (getenv "CCUSAGE_TIMEZONE" "Asia/Tokyo")
        config    (getenv "CCUSAGE_CONFIG" (str (fs/home) "/.claude/ccusage.json"))]

    (when (fs/exists? snap-dir)
      (println (str "Snapshot already exists: " snap-dir))
      (System/exit 0))

    (let [ccusage (resolve-ccusage)
          version (ccusage-version ccusage)]
      (fs/create-dirs parent)
      (let [tmp (str (fs/create-temp-dir {:dir parent :prefix (str "." month-number ".tmp.")}))]
        ;; signal/異常時に tmp を掃除 (bash の trap cleanup)
        (.addShutdownHook (Runtime/getRuntime)
                          (Thread. #(when (fs/exists? tmp) (fs/delete-tree tmp))))
        (try
          (let [run-report
                (fn [output & subcmd]
                  (let [out (sh-out (into (vec ccusage)
                                          (concat subcmd
                                                  ["--json" "--offline" "--mode" "auto"
                                                   "--timezone" timezone
                                                   "--since" start-date "--until" end-date])))]
                    (json/parse-string out) ; 妥当性検証 (壊れていれば例外)
                    (spit (str tmp "/" output) out)))]
            (run-report "all-daily.json" "daily" "--all")
            (run-report "claude-projects.json" "claude" "daily" "--instances")

            (let [reports {"allDaily"       {"file" "all-daily.json"        "command" ["daily" "--all"]}
                           "claudeProjects" {"file" "claude-projects.json"  "command" ["claude" "daily" "--instances"]}}
                  reports (reduce-kv (fn [m k v]
                                       (assoc m k (assoc v "sha256" (sha256 (str tmp "/" (v "file"))))))
                                     (array-map) reports)
                  manifest (array-map
                            "schemaVersion" 1
                            "generatedAt"   (str (Instant/now))
                            "period"        (array-map "month" (str year "-" month-number)
                                                       "since" start-date "until" end-date
                                                       "timezone" timezone)
                            "ccusage"       (array-map "version" version
                                                       "offline" true
                                                       "costMode" "auto"
                                                       "configSha256" (when (fs/regular-file? config) (sha256 config)))
                            "reports"       reports)]
              (spit (str tmp "/manifest.json")
                    (str (json/generate-string manifest {:pretty true}) "\n")))

            (fs/move tmp snap-dir)
            (println (str "Saved snapshot: " snap-dir)))
          (catch Exception e
            (when (fs/exists? tmp) (fs/delete-tree tmp))
            (die 1 (str "snapshot failed: " (.getMessage e)))))))))

(apply -main *command-line-args*)
