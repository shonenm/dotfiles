#!/bin/bash
# wt - git worktree + tmux window 統合管理CLI
set -euo pipefail

# shellcheck source=wt-lib.sh
source "$(dirname "$0")/wt-lib.sh"

# CLI-specific: error exits the process
error() { wt_error "$@"; exit 1; }

wt_check_git || exit 1

# --- Subcommands ---

cmd_new() {
  local branch="${1:-}"
  [[ -z "$branch" ]] && error "Usage: wt new <branch> [base]"
  wt_create "$branch" "${2:-}" > /dev/null || exit 1
}

cmd_checkout() {
  local pr_number="${1:-}"
  [[ -z "$pr_number" ]] && error "Usage: wt checkout <pr-number>"

  command -v gh &>/dev/null || error "gh CLI is not installed"

  local pr_json
  pr_json="$(gh pr view "$pr_number" --json headRefName,baseRefName)" || error "Failed to get PR #$pr_number"

  local branch base
  branch="$(echo "$pr_json" | jq -r '.headRefName')"
  base="$(echo "$pr_json" | jq -r '.baseRefName')"

  wt_info "PR #$pr_number: $branch (base: $base)"

  git fetch origin "$branch"

  wt_create "$branch" > /dev/null || exit 1
}

cmd_list() {
  local repo
  repo="$(wt_repo_name)"

  local found=false
  while IFS= read -r line; do
    local wt_dir branch_info
    wt_dir="$(echo "$line" | awk '{print $1}')"
    branch_info="$(echo "$line" | sed 's/.*\[//' | sed 's/\]//')"

    [[ "$wt_dir" == *--wt--* ]] || continue
    found=true

    local win="${repo}#${branch_info}"
    local win_status=""
    if wt_window_exists "$win"; then
      win_status="[tmux]"
    fi

    printf "  %-40s %-20s %s\n" "$branch_info" "$wt_dir" "$win_status"
  done < <(git worktree list)

  if [[ "$found" == false ]]; then
    wt_info "No worktrees found"
  fi
}

cmd_delete() {
  local branch="${1:-}"
  [[ -z "$branch" ]] && error "Usage: wt delete <branch>"
  wt_delete "$branch" || exit 1
}

cmd_clean() {
  wt_clean
}

# --- Main ---

case "${1:-}" in
  new)      cmd_new "${2:-}" "${3:-}" ;;
  checkout) cmd_checkout "${2:-}" ;;
  list)     cmd_list ;;
  delete)   cmd_delete "${2:-}" ;;
  clean)    cmd_clean ;;
  help|*)
    cat <<EOF
wt - git worktree + tmux window manager

Usage:
  wt new <branch> [base]     Create worktree + tmux window
  wt checkout <pr-number>    Checkout PR into worktree
  wt list                    List worktrees
  wt delete <branch>         Remove worktree + tmux window
  wt clean                   Remove all worktrees

Examples:
  wt new fix-bug
  wt new feat/login main
  wt checkout 42
  wt delete fix-bug
EOF
    ;;
esac
