#!/usr/bin/env bash
# wt-traefik-up - wt-up.sh wrapper that attaches Traefik (dev-gateway) routing
#
# Usage: wt-traefik-up <wt-name> [wt-up.sh args...]
#
# Workflow:
#   1. Runs wt-up.sh normally (network create, compose up, kc-sync, etc.)
#   2. Generates a Traefik overlay (compose.traefik.yml) that attaches the
#      worktree's nginx to dev-edge and adds SNI passthrough labels.
#   3. Recreates nginx with the overlay so Traefik discovers the route.
#
# After this, the wt is reachable through dev-gateway entrypoints:
#   https://app-<wt>.localhost:48080
#   https://api-<wt>.localhost:48080  (and ws-/s3-)
#
# Prerequisites:
#   - syntopic repo at $SYNTOPIC_DIR (default: ~/syntopic)
#   - dev-gateway up (creates dev-edge network)
#
# Why a wrapper (vs editing wt-up.sh): keeps Traefik integration entirely in
# personal tooling — the shared wt-up.sh stays untouched, so other developers
# who don't run dev-gateway are unaffected.

set -euo pipefail

SYNTOPIC_DIR="${SYNTOPIC_DIR:-$HOME/syntopic}"
WT_UP="${SYNTOPIC_DIR}/scripts/wt-up.sh"

usage() {
  cat <<USAGE
wt-traefik-up - wt-up.sh wrapper with Traefik integration

Usage:
  wt-traefik-up <wt-name> [--services svc1,svc2] [--port-offset auto|N]

Environment:
  SYNTOPIC_DIR   path to syntopic repo (default: \$HOME/syntopic)

Prereqs:
  - dev-gateway up <host>  (creates docker network 'dev-edge')
USAGE
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || "${1:-}" == "help" || $# -eq 0 ]]; then
  usage
  exit 0
fi

# --- Pre-flight ---
if [[ ! -x "$WT_UP" ]]; then
  echo "Error: wt-up.sh not found or not executable: $WT_UP" >&2
  echo "Set SYNTOPIC_DIR to the path of your syntopic checkout." >&2
  exit 1
fi

if ! docker network inspect dev-edge >/dev/null 2>&1; then
  echo "Error: docker network 'dev-edge' does not exist." >&2
  echo "Bring up the gateway first: dev-gateway up <host>" >&2
  exit 1
fi

# --- Extract wt-name from args (first non-flag positional) ---
wt_name=""
for arg in "$@"; do
  case "$arg" in
    -*) ;;
    *)
      if [[ -z "$wt_name" ]]; then
        wt_name="$arg"
      fi
      ;;
  esac
done

if [[ -z "$wt_name" ]]; then
  echo "Error: wt-name required" >&2
  usage
  exit 1
fi

# --- Run wt-up.sh (full setup: network create, compose up, kc-sync) ---
echo "[wt-traefik-up] Running wt-up.sh ${*}"
"$WT_UP" "$@"

# --- Locate generated compose ---
compose_dir="${XDG_RUNTIME_DIR:-${TMPDIR:-$HOME/.cache}}/ralph/wt-compose-${USER:-unknown}/${wt_name}"
compose_file="${compose_dir}/compose.yml"
if [[ ! -f "$compose_file" ]]; then
  echo "Error: expected ${compose_file} after wt-up.sh" >&2
  exit 1
fi

# --- Extract HTTPS port from nginx ports block ---
# Matches first "127.0.0.1:<port>:<port>" inside the nginx service.
https_port="$(
  awk '
    /^  [a-z][a-z0-9_-]*:[[:space:]]*$/ {
      svc = $1
      sub(/:$/, "", svc)
      in_nginx = (svc == "nginx") ? 1 : 0
      next
    }
    in_nginx && match($0, /127\.0\.0\.1:[0-9]+:[0-9]+/) {
      m = substr($0, RSTART, RLENGTH)
      n = split(m, a, ":")
      print a[3]
      exit
    }
  ' "$compose_file"
)"

if [[ -z "$https_port" ]]; then
  echo "Error: could not extract https_port from $compose_file" >&2
  exit 1
fi

# --- Generate Traefik overlay ---
overlay="${compose_dir}/compose.traefik.yml"
cat > "$overlay" <<YAML
# Auto-generated by wt-traefik-up. Adds dev-gateway routing for ${wt_name}.

networks:
  edge:
    name: dev-edge
    external: true

services:
  nginx:
    networks:
      - edge
    labels:
      traefik.enable: "true"
      traefik.docker.network: "dev-edge"
      traefik.tcp.routers.wt-${wt_name}.rule: "HostSNI(\`app-${wt_name}.localhost\`) || HostSNI(\`api-${wt_name}.localhost\`) || HostSNI(\`s3-${wt_name}.localhost\`) || HostSNI(\`ws-${wt_name}.localhost\`)"
      traefik.tcp.routers.wt-${wt_name}.tls.passthrough: "true"
      traefik.tcp.routers.wt-${wt_name}.entrypoints: "websecure"
      traefik.tcp.services.wt-${wt_name}.loadbalancer.server.port: "${https_port}"
YAML

echo "[wt-traefik-up] Wrote ${overlay}"

# --- Recreate nginx with overlay (only nginx is affected; web/bff stay) ---
# Project name must match wt-up.sh (`wt-<name>`); without -p the parent directory
# name is used and compose treats existing containers as foreign, then trips on
# container_name conflicts. --no-deps keeps web/bff untouched.
cd "$compose_dir"
echo "[wt-traefik-up] Recreating nginx with Traefik overlay..."
docker compose -p "wt-${wt_name}" -f compose.yml -f compose.traefik.yml up -d --no-deps nginx

cat <<INFO

[wt-traefik-up] Done. ${wt_name} reachable via dev-gateway:
  https://app-${wt_name}.localhost:48080
  https://api-${wt_name}.localhost:48080
  https://s3-${wt_name}.localhost:48080
  https://ws-${wt_name}.localhost:48080
  (existing https://...:${https_port} URL also continues to work)
INFO
