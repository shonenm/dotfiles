#!/bin/bash
# tmux-popup-in-container — run a command inside the current tmux session's
# docker container when the session is wired via tmux-docker-enter; otherwise
# run it on the host.
#
# Used from popup-manager definitions so that popups like lazygit / lazydocker
# operate on the container-side project instead of the host cwd (which often
# isn't even a git repo / doesn't have the right credentials).
#
# Usage:
#   tmux-popup-in-container lazygit
#   tmux-popup-in-container gh dash
#   tmux-popup-in-container psql "$DATABASE_URL"

set -eu

[[ $# -ge 1 ]] || { echo "usage: $(basename "$0") <cmd> [args...]" >&2; exit 2; }

# Resolve pane context (CONTAINER, CWD, SESSION, PANE_ID)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
eval "$("$SCRIPT_DIR/tmux-pane-context")"

if [[ -n "${CONTAINER:-}" ]]; then
  args=(exec -it)
  [[ -n "${TERM:-}" ]] && args+=(-e "TERM=$TERM")
  [[ -n "${CWD:-}" ]]  && args+=(-w "$CWD")
  # Run via `zsh -ic` (interactive) so the container's full shell init
  # executes: .zshenv PATH additions, mise activate (which makes
  # mise-managed tools like `gh` discoverable), dotfiles aliases, etc.
  # Image-level ENV PATH varies across Dockerfiles and mise shims are
  # absent in non-interactive zsh — `zsh -ic` is the minimum that
  # reliably sees every tool the user has in their zshrc.
  # `printf %q` requotes argv safely so zsh re-parses to the same words.
  # zle warnings on stderr are harmless (zle line editor not usable in -c).
  cmd_str=$(printf '%q ' "$@")
  args+=("$CONTAINER" zsh -ic "exec $cmd_str")
  exec docker "${args[@]}"
fi

# Fallback: run on host. Use `zsh -ic` (interactive) so .zshrc init runs —
# specifically `mise activate` which is what makes mise-managed tools (gh,
# node, uv, ...) discoverable in PATH. Plain `exec "$@"` would only see
# tools in static PATH (~/.local/bin via .zshenv) and miss everything else.
host_cmd_str=$(printf '%q ' "$@")
exec zsh -ic "exec $host_cmd_str"
