#!/usr/bin/env bash
# cs - Claude Code Session Manager
# FZF-based session browser with preview, resume, and delete capabilities

set -euo pipefail

CLAUDE_PROJECTS_DIR="${HOME}/.claude/projects"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

show_help() {
    cat <<EOF
Usage: cs [OPTIONS]

Claude Code Session Manager - Browse, preview, resume, and delete sessions

OPTIONS:
    -h, --help     Show this help message
    -d, --delete   Delete mode (shows delete instructions)
    -c, --clean    Clean old sessions (older than 30 days)

KEYBINDINGS:
    Enter          Resume selected session
    Ctrl-D         Delete selected session
    Ctrl-C         Cancel
    Tab            Toggle preview
    ?              Toggle help

EXAMPLES:
    cs             Launch interactive session browser
    cs --clean     Remove sessions older than 30 days
EOF
}

# Get first user message from session as preview
get_session_preview() {
    local session_file="$1"

    if [[ ! -f "$session_file" ]]; then
        echo "No session data"
        return
    fi

    # Extract first user message
    local preview
    preview=$(grep '"type":"user"' "$session_file" 2>/dev/null | head -5 | \
        jq -r 'select(.type == "user") | .message.content | if type == "string" then . elif type == "array" then (.[0].text // .[0].content // .) else . end' 2>/dev/null | \
        grep -v '^Base directory for' | \
        grep -v '^<command' | \
        sed 's/<[^>]*>//g' | \
        head -1 | \
        head -c 150)

    if [[ -z "$preview" ]]; then
        echo "(No user messages)"
    else
        echo "$preview"
    fi
}

# Get detailed preview for FZF preview window
get_detailed_preview() {
    local session_file="$1"

    echo -e "${BLUE}Session:${NC} $(basename "$session_file" .jsonl)"
    echo -e "${BLUE}Modified:${NC} $(stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "$session_file" 2>/dev/null || stat -c "%y" "$session_file" 2>/dev/null | cut -d'.' -f1)"
    echo -e "${BLUE}Size:${NC} $(du -h "$session_file" | cut -f1)"
    echo ""
    echo -e "${YELLOW}Recent messages:${NC}"
    echo "─────────────────────────────────────────────────"

    # Show last few user/assistant messages
    grep '"type":"user"\|"type":"assistant"' "$session_file" 2>/dev/null | \
        tail -10 | \
        jq -r 'if .type == "user" then
                 "USER: " + (.message.content | if type == "string" then . elif type == "array" then (.[0].text // .[0].content // .) else . end)
               else
                 "ASSISTANT: " + (.message.content[0].text // .message.content[0].content // "(no content)")
               end' 2>/dev/null | \
        sed 's/<[^>]*>//g' | \
        fold -w 80 -s || echo "(No messages found)"
}

# List all sessions
list_sessions() {
    local format="${1:-simple}"

    if [[ ! -d "$CLAUDE_PROJECTS_DIR" ]]; then
        echo "Error: Claude projects directory not found at $CLAUDE_PROJECTS_DIR" >&2
        exit 1
    fi

    # Find all .jsonl session files (not in subagents/)
    while IFS= read -r session_file; do
        local session_id
        session_id=$(basename "$session_file" .jsonl)

        # Skip if it's a directory-based session (has UUID directory)
        if [[ -d "${session_file%.jsonl}" ]]; then
            continue
        fi

        local mtime
        mtime=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$session_file" 2>/dev/null || \
                stat -c "%y" "$session_file" 2>/dev/null | cut -d'.' -f1)

        local project_dir
        project_dir=$(dirname "$session_file")
        project_dir=$(basename "$project_dir")

        if [[ "$format" == "fzf" ]]; then
            local preview
            preview=$(get_session_preview "$session_file")
            echo "${session_file}|${mtime}|${project_dir}|${preview}"
        else
            echo "$session_file"
        fi
    done < <(find "$CLAUDE_PROJECTS_DIR" -name "*.jsonl" -type f ! -path "*/subagents/*" -print0 2>/dev/null | \
        xargs -0 ls -t 2>/dev/null)
}

# Delete session
delete_session() {
    local session_file="$1"

    if [[ ! -f "$session_file" ]]; then
        echo -e "${RED}Error: Session file not found${NC}" >&2
        return 1
    fi

    local session_id
    session_id=$(basename "$session_file" .jsonl)

    echo -e "${YELLOW}Deleting session:${NC} $session_id"

    # Delete the .jsonl file
    rm -f "$session_file"

    # Delete the directory if it exists
    local session_dir="${session_file%.jsonl}"
    if [[ -d "$session_dir" ]]; then
        rm -rf "$session_dir"
    fi

    echo -e "${GREEN}Deleted${NC}"
}

# Clean old sessions
clean_old_sessions() {
    local days="${1:-30}"

    echo -e "${YELLOW}Finding sessions older than $days days...${NC}"

    local count=0
    while IFS= read -r session_file; do
        local age_days
        age_days=$(( ($(date +%s) - $(stat -f "%m" "$session_file" 2>/dev/null || stat -c "%Y" "$session_file")) / 86400 ))

        if [[ $age_days -gt $days ]]; then
            echo "  $(basename "$session_file" .jsonl) (${age_days} days old)"
            ((count++))
        fi
    done < <(find "$CLAUDE_PROJECTS_DIR" -name "*.jsonl" -type f ! -path "*/subagents/*" 2>/dev/null)

    if [[ $count -eq 0 ]]; then
        echo -e "${GREEN}No old sessions found${NC}"
        return 0
    fi

    echo ""
    read -p "Delete these $count sessions? [y/N] " -n 1 -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        while IFS= read -r session_file; do
            local age_days
            age_days=$(( ($(date +%s) - $(stat -f "%m" "$session_file" 2>/dev/null || stat -c "%Y" "$session_file")) / 86400 ))

            if [[ $age_days -gt $days ]]; then
                delete_session "$session_file"
            fi
        done < <(find "$CLAUDE_PROJECTS_DIR" -name "*.jsonl" -type f ! -path "*/subagents/*" 2>/dev/null)

        echo -e "${GREEN}Cleaned $count sessions${NC}"
    else
        echo "Cancelled"
    fi
}

# Interactive browser
browse_sessions() {
    if ! command -v fzf &> /dev/null; then
        echo "Error: fzf is required but not installed" >&2
        echo "Install with: brew install fzf (macOS) or apt install fzf (Linux)" >&2
        exit 1
    fi

    local selected
    selected=$(list_sessions fzf | \
        fzf --with-nth=2,3,4 \
            --delimiter='|' \
            --preview="$(declare -f get_detailed_preview); get_detailed_preview {1}" \
            --preview-window=right:60%:wrap \
            --header='Enter: Resume | Ctrl-D: Delete | Ctrl-C: Cancel' \
            --bind="ctrl-d:execute($(declare -f delete_session); delete_session {1})+reload($(declare -f list_sessions get_session_preview); list_sessions fzf)" \
            --height=100% \
            --layout=reverse \
            --border \
            --prompt='Sessions> ' | \
            cut -d'|' -f1)

    if [[ -n "$selected" ]]; then
        local session_id
        session_id=$(basename "$selected" .jsonl)

        echo -e "${GREEN}Resuming session:${NC} $session_id"
        exec claude --resume "$session_id"
    fi
}

# Main
main() {
    case "${1:-}" in
        -h|--help)
            show_help
            ;;
        -c|--clean)
            clean_old_sessions "${2:-30}"
            ;;
        -d|--delete)
            echo "Use Ctrl-D in the interactive browser to delete sessions"
            browse_sessions
            ;;
        *)
            browse_sessions
            ;;
    esac
}

main "$@"
