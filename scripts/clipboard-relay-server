#!/bin/bash
# clipboard-relay-server — listen on 127.0.0.1:2489, pipe each connection to pbcopy.
#
# Companion to scripts/clipboard-copy. Receives bytes from remote SSH
# sessions (via RemoteForward 2489) and writes them into the host clipboard.
# Each TCP connection is one clipboard payload; nc exits on EOF, then we
# loop back to listen again.
#
# Run on macOS via launchd (templates/com.user.clipboard-relay.plist).

set -u

PORT=2489
HOST=127.0.0.1

while true; do
  nc -l "$HOST" "$PORT" | pbcopy
done
